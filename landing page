<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elite Cricket Academy</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            line-height: 1.6;
        }

        header {
            background: #0d47a1;
            color: white;
            padding: 15px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        header h1 {
            font-size: 24px;
        }

        nav a {
            color: white;
            margin-left: 20px;
            text-decoration: none;
            font-weight: bold;
        }

        .hero {
            height: 90vh;
            background: url('https://images.unsplash.com/photo-1593341646782-e0b495cff86d') no-repeat center/cover;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
        }

        .hero h2 {
            font-size: 48px;
        }

        .hero p {
            margin: 20px 0;
            font-size: 18px;
        }

        .hero button {
            padding: 12px 25px;
            border: none;
            background: #ff9800;
            color: white;
            font-size: 16px;
            cursor: pointer;
            border-radius: 5px;
        }

        .section {
            padding: 60px 50px;
            text-align: center;
        }

        .section h2 {
            margin-bottom: 30px;
            font-size: 32px;
            color: #0d47a1;
        }

        .cards {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .card {
            background: #f4f4f4;
            padding: 20px;
            width: 280px;
            border-radius: 10px;
            transition: 0.3s;
        }

        .card:hover {
            transform: translateY(-10px);
        }

        .card h3 {
            margin-bottom: 10px;
        }

        .testimonials {
            background: #e3f2fd;
        }

        .testimonial {
            max-width: 600px;
            margin: auto;
            margin-bottom: 20px;
        }

        .contact {
            background: #0d47a1;
            color: white;
        }

        .contact input, .contact textarea {
            width: 80%;
            padding: 10px;
            margin: 10px 0;
            border: none;
            border-radius: 5px;
        }

        .contact button {
            padding: 10px 20px;
            background: #ff9800;
            border: none;
            color: white;
            cursor: pointer;
        }

        footer {
            text-align: center;
            padding: 15px;
            background: #002171;
            color: white;
        }

        @media(max-width: 768px) {
            .hero h2 {
                font-size: 30px;
            }

            .cards {
                flex-direction: column;
                align-items: center;
            }
        }
    </style>
</head>
<body>

<header>
    <h1>Elite Cricket Academy</h1>
    <nav>
        <a href="#">Home</a>
        <a href="#">Programs</a>
        <a href="#">Coaches</a>
        <a href="#">Contact</a>
    </nav>
</header>

<section class="hero">
    <div>
        <h2>Train Like a Champion 🏏</h2>
        <p>Join the best cricket academy and elevate your game</p>
        <button>Join Now</button>
    </div>
</section>

<section class="section">
    <h2>Our Programs</h2>
    <div class="cards">
        <div class="card">
            <h3>Beginner Training</h3>
            <p>Learn basics with professional guidance.</p>
        </div>
        <div class="card">
            <h3>Advanced Coaching</h3>
            <p>Improve techniques and match skills.</p>
        </div>
        <div class="card">
            <h3>Fitness Training</h3>
            <p>Build strength and endurance.</p>
        </div>
    </div>
</section>

<section class="section testimonials">
    <h2>What Students Say</h2>
    <div class="testimonial">
        <p>"This academy transformed my game completely!"</p>
        <strong>- Rahul</strong>
    </div>
    <div class="testimonial">
        <p>"Amazing coaches and facilities."</p>
        <strong>- Arjun</strong>
    </div>
</section>

<section class="section contact">
    <h2>Contact Us</h2>
    <input type="text" placeholder="Your Name"><br>
    <input type="email" placeholder="Your Email"><br>
    <textarea rows="4" placeholder="Message"></textarea><br>
    <button>Send Message</button>
</section>

<footer>
    <p>© 2026 Elite Cricket Academy | All Rights Reserved</p>
</footer>

</body>
</html>
